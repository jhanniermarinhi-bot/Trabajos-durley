#include <iostream>
#include <cmath> 

using namespace std;


double calcularAreaCirculo(double radio);
long long calcularFactorial(int n);
void verificarParImpar(int n);

int main() {
    int opcion;
    
    do {
        
        cout << "           MENU DE FUNCIONES            " << endl;
        
        cout << "1. Calcular area de un circulo" << endl;
        cout << "2. Calcular factorial de un numero" << endl;
        cout << "3. Verificar si es Par o Impar" << endl;
        cout << "4. Salir" << endl;
        cout << "Elija una opcion: ";
        cin >> opcion;

        switch (opcion) {
            case 1: {
                double r;
                cout << "Ingrese el radio del circulo: ";
                cin >> r;
                cout << "El area es: " << calcularAreaCirculo(r) << endl;
                break;
            }
            case 2: {
                int num;
                cout << "Ingrese un numero entero positivo: ";
                cin >> num;
                if (num < 0) cout << "No existe factorial de numeros negativos." << endl;
                else cout << "El factorial de " << num << " es: " << calcularFactorial(num) << endl;
                break;
            }
            case 3: {
                int num;
                cout << "Ingrese un numero: ";
                cin >> num;
                verificarParImpar(num);
                break;
            }
            case 4:
                cout << "Saliendo..." << endl;
                break;
            default:
                cout << "Opcion no valida." << endl;
        }
    } while (opcion != 4);

    return 0;
}




double calcularAreaCirculo(double radio) {
    
    return 3.14159 * (radio * radio);
}


long long calcularFactorial(int n) {
    long long resultado = 1;
    for (int i = 1; i <= n; i++) {
        resultado *= i;
    }
    return resultado;
}


void verificarParImpar(int n) {
    if (n % 2 == 0) {
        cout << "El numero " << n << " es PAR." << endl;
    } else {
        cout << "El numero " << n << " es IMPAR." << endl;
    }
}
