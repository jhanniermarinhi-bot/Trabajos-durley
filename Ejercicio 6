#include <iostream>
#include <iomanip>
#include <cmath>

using namespace std;

int main() {
    int cantidadEstudiantes = 0;
    double* notas = nullptr;  
    
    
    
    cout << "   SISTEMA DE CALIFICACIONES" << endl;
   
    
    do {
        cout << "\nIngrese la cantidad de estudiantes: ";
        cin >> cantidadEstudiantes;
        
        
        if (cantidadEstudiantes <= 0) {
            cout << "Error: La cantidad debe ser mayor a 0." << endl;
            cin.clear();
            cin.ignore(10000, '\n');
        }
    } while (cantidadEstudiantes <= 0);
    
    
    notas = new double[cantidadEstudiantes];
    
    if (notas == nullptr) {
        cout << "Error: No se pudo asignar memoria." << endl;
        return 1;  
    }
    
    cout << "\n INGRESO DE CALIFICACIONES " << endl;
    
    
    for (int i = 0; i < cantidadEstudiantes; i++) {
        do {
            cout << "Ingrese la calificacion del estudiante " << (i + 1) << " (0-100): ";
            cin >> notas[i];
            
            if (cin.fail() || notas[i] < 0 || notas[i] > 100) {
                cout << "Error: Ingrese un valor válido entre 0 y 100." << endl;
                cin.clear();
                cin.ignore(10000, '\n');
                notas[i] = -1;  
            }
        } while (notas[i] < 0 || notas[i] > 100);
    }
    
    
    double suma = 0;
    double notaMayor = notas[0];
    double notaMenor = notas[0];
    
    
    for (int i = 0; i < cantidadEstudiantes; i++) {
        suma += notas[i];
        
        if (notas[i] > notaMayor) {
            notaMayor = notas[i];
        }
        
        if (notas[i] < notaMenor) {
            notaMenor = notas[i];
        }
    }
    
    double promedio = suma / cantidadEstudiantes;
    
    
    cout << "\n--- RESULTADOS ---" << endl;
    cout << "\nCalificaciones ingresadas:" << endl;
    
    for (int i = 0; i < cantidadEstudiantes; i++) {
        cout << "  Estudiante " << (i + 1) << ": " 
             << fixed << setprecision(2) << notas[i] << endl;
    }
    
   
    cout << "ESTADÍSTICAS:" << endl;
    
    cout << "Promedio:           " << fixed << setprecision(2) << promedio << endl;
    cout << "Calificacion Mayor: " << fixed << setprecision(2) << notaMayor << endl;
    cout << "Calificacion Menor: " << fixed << setprecision(2) << notaMenor << endl;
    cout << "Diferencia:         " << fixed << setprecision(2) << (notaMayor - notaMenor) << endl;
    
    
    
    delete[] notas;  
    notas = nullptr; 
    
    cout << "Memoria liberada correctamente." << endl;
    
    return 0;
}
